datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model AdminUser {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
}

model Job {
  id           String        @id @default(uuid())
  title        String
  description  String
  department   String
  location     String
  type         String        // Full-time, Part-time, Contract, Remote
  salary       String?
  status       String        @default("PUBLISHED") // DRAFT, PUBLISHED, ARCHIVED
  featured     Boolean       @default(false)
  requirements String?       // JSON string or long text list
  benefits     String?       // JSON string or long text list
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
}

model Application {
  id            String   @id @default(uuid())
  name          String
  email         String
  phone         String
  resumePath    String
  portfolioLink String?
  experience    String   // in years
  linkedIn      String?
  message       String?
  status        String   @default("APPLIED") // APPLIED, REVIEWING, INTERVIEWING, OFFERED, REJECTED
  createdAt     DateTime @default(now())
  jobId         String
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id             String    @id @default(uuid())
  title          String
  slug           String    @unique
  content        String
  summary        String
  coverImage     String?
  status         String    @default("PUBLISHED") // DRAFT, PUBLISHED
  tags           String    // Comma-separated tags
  readingTime    Int       @default(5)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  publishedAt    DateTime? @default(now())
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("UNREAD") // UNREAD, READ, ARCHIVED
  createdAt DateTime @default(now())
}
